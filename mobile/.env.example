# Mobile app environment variables (local dev)
# Copy to .env and fill in your values. Never commit .env to git.

# Backend API — local Wi-Fi IP or Render HTTPS URL
EXPO_PUBLIC_API_URL=http://YOUR_LAPTOP_IP:8000

# Cloudinary (selfie uploads)
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=attendance_selfies
